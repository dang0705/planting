    "check:diagnose-smoke:stable-marking": "node scripts/terminal-e2e/cloudbase-http-check.mjs --smoke=diagnose --env=cloud1-2grufevs395a9d5e --app-env=development --terminal-e2e=true --device-id=codex-dev-e2e-stable-marking --observed-evidence-set='[{\"observedEvidenceSetId\":\"terminal_smoke::stable_natural_marking_pattern\",\"evidenceKey\":\"stable_natural_marking_pattern\",\"evidenceType\":\"symptom\",\"symptomKey\":\"stable_natural_marking_pattern\",\"symptomCn\":\"长期稳定斑驳模式\",\"confidence\":0.99,\"sourceType\":\"user_answer\",\"currentStatus\":\"active\",\"targetLayer\":\"observed_evidence_set\"}]' --answer-pattern=yes,yes,yes --expect-outcome=non_problematic --expect-non-problematic-type=stable_natural_marking",
