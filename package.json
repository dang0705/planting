    "check:diagnose-visual-regression": "node scripts/terminal-e2e/run-visual-symptom-batch.mjs --env=cloud1-2grufevs395a9d5e --case-groups-file=scripts/terminal-e2e/manifests/diagnose-visual-regression.manifest.json --skip-auth=true --force-anonymous-auth=true --app-env=development --keep-uploaded-image=false --max-followup-loops=2 --start-mode=sync --report-file=scripts/terminal-e2e/manifests/diagnose-visual-regression.report.json",
    "check:diagnose-outcome-regression": "node scripts/terminal-e2e/run-diagnose-outcome-suite.mjs --env=cloud1-2grufevs395a9d5e --case-groups-file=scripts/terminal-e2e/manifests/diagnose-outcome-regression.manifest.json --skip-auth=true --force-anonymous-auth=true --app-env=development --max-followup-loops=3 --case-retries=3 --case-retry-delay-ms=2500 --start-retries=4 --answer-retries=4 --retry-delay-ms=2500 --suite-case-attempts=3 --suite-case-delay-ms=2000 --report-file=scripts/terminal-e2e/manifests/diagnose-outcome-regression.report.json",
