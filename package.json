    "check:diagnose-smoke": "node scripts/terminal-e2e/cloudbase-http-check.mjs --smoke=diagnose --env=cloud1-2grufevs395a9d5e --app-env=development --terminal-e2e=true --device-id=codex-dev-e2e-smoke",
    "check:diagnose-smoke:uncertain": "node scripts/terminal-e2e/cloudbase-http-check.mjs --smoke=diagnose --env=cloud1-2grufevs395a9d5e --app-env=development --terminal-e2e=true --device-id=codex-dev-e2e-uncertain-unknown --answer-pattern=unknown,unknown,unknown --expect-outcome=uncertain",
