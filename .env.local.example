# 本地 CloudBase HTTP 云函数调试示例
# 复制为 .env.local 后按需填写；.env.local 已被 .gitignore 忽略。

# 本地 gateway 默认端口；前端本地脚本会默认使用 http://127.0.0.1:3010
CLOUDBASE_LOCAL_FUNCTIONS_PORT=3010

# 小程序本地模式默认会自动启动完整本地函数 gateway。
# 如需手动管理 dev:functions，可关闭自动启动：
# CLOUDBASE_LOCAL_AUTO_START_FUNCTIONS=false

# 如只做单函数专项验证，可临时缩小检查范围，例如：
# CLOUDBASE_LOCAL_REQUIRED_FUNCTIONS=diagnose-http

# 微信开发者工具真机预览或网络隔离时，可手动指定本机局域网 IP
# CLOUDBASE_LOCAL_FUNCTIONS_HOST_IP=192.168.1.10

# 小程序本地调试使用的开发 openid。不要填真实用户敏感信息。
VITE_DEV_OPENID=dev_terminal_mp_local

# 默认 CloudBase 环境 ID，生产/测试云端路径仍由现有脚本控制。
VITE_CLOUDBASE_ENV_ID=cloud1-2grufevs395a9d5e
CLOUDBASE_ENV_ID=cloud1-2grufevs395a9d5e
TCB_ENV=cloud1-2grufevs395a9d5e

# 本地函数内部默认写读 development schema，不要在本地调试时指向 production。
APP_ENV=development
SCHEMA_ENV=development
SQL_DATABASE=cloud1_dev

# 下面只列变量名，真实值只能放在未提交的 .env.local、shell 环境或 GitHub Secrets。
# 本地 CloudBase CLI / smoke 如需凭据，可临时填写到 .env.local 后使用。
CLOUDBASE_SECRET_ID=
CLOUDBASE_SECRET_KEY=
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENTCLOUD_SECRETID=
TENCENTCLOUD_SECRETKEY=

# GitHub Actions 小程序发布变量。appid 可放 GitHub Variables，私钥必须放 GitHub Secrets。
WECHAT_MINIPROGRAM_APPID=
WECHAT_MINIPROGRAM_PRIVATE_KEY=
MINIPROGRAM_CI_ACTION=preview
MINIPROGRAM_CI_ROBOT=1
