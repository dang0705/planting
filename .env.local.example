# 本地 CloudBase HTTP 云函数调试示例
# 复制为 .env.local 后按需填写；.env.local 已被 .gitignore 忽略。

# 本地 gateway 默认端口；前端本地脚本会默认使用 http://127.0.0.1:3000
CLOUDBASE_LOCAL_FUNCTIONS_PORT=3000

# 微信开发者工具真机预览或网络隔离时，可手动指定本机局域网 IP
# CLOUDBASE_LOCAL_FUNCTIONS_HOST_IP=192.168.1.10

# 小程序本地调试使用的开发 openid。不要填真实用户敏感信息。
VITE_DEV_OPENID=dev_terminal_mp_local

# 默认 CloudBase 环境 ID，生产/测试云端路径仍由现有脚本控制。
VITE_CLOUDBASE_ENV_ID=cloud1-2grufevs395a9d5e

# 本地函数内部默认写读 development schema，不要在本地调试时指向 production。
APP_ENV=development
SCHEMA_ENV=development
SQL_DATABASE=cloud1_dev
